<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="356dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/ivGood"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/img_mid_socks"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"/>
    
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivHeartInCircle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:layout_constraintTop_toTopOf="@id/ivGood"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@color/white"
        app:shapeAppearanceOverlay="@style/Circle"
        app:srcCompat="@drawable/empty_heart"
        android:scaleType="centerInside"/>

    <TextView
        android:id="@+id/tvBestSeller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BestSeller"
        android:textColor="@color/highlight"
        android:textSize="14sp"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/ivGood"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="14dp"/>

    <TextView
        android:id="@+id/tvGood"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nike Everyday Plus Cushioned"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/tvBestSeller"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvGoodDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Training Ankle Socks (6 Pairs)"
        android:textSize="14sp"
        android:textColor="@color/grey"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/tvGood"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvGoodColorDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="5 Colours"
        android:textColor="@color/grey"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGoodDescription"/>

    <TextView
        android:id="@+id/tvGoodPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="US$125"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/tvGoodColorDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>